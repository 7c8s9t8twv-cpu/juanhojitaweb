# ─────────────────────────────────────────────────────────────
# COPIA este archivo como .env.local y rellena tus datos reales.
# .env.local NUNCA se sube a GitHub (está en .gitignore).
# En Hostinger, añade estas mismas variables en:
#   hPanel → Websites → Node.js → tu app → Environment variables
# ─────────────────────────────────────────────────────────────

# Datos SMTP de tu correo Hostinger (hPanel → Emails → Configuración)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hola@juanhojita.com
SMTP_PASS=tu_contraseña_del_buzon

# Correo donde quieres recibir los avisos de nuevos diagnósticos
NOTIFY_TO=hola@juanhojita.com
